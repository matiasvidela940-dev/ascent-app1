generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Athlete {
  id         String         @id @default(cuid())
  name       String
  email      String         @unique
  accessCode String         @unique
  level      String         @default("INTERMEDIO")
  targetRace String?
  raceDate   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  weeks      TrainingWeek[]

  @@map("athletes")
}

model TrainingWeek {
  id        String        @id @default(cuid())
  athleteId String
  weekNumber Int
  weekType  String
  startDate DateTime
  days      TrainingDay[]

  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
  @@map("training_weeks")
}

model TrainingDay {
  id              String   @id @default(cuid())
  weekId          String
  dayNumber       Int
  dayLabel        String
  type            String
  title           String
  description     String
  distance        String?
  terrain         String?
  pace            String?
  heartRateMin    Int?
  heartRateMax    Int?
  isKeySession    Boolean  @default(false)
  isLongRun       Boolean  @default(false)
  warmup          String?
  mainBlock       String?
  cooldown        String?
  coachTip        String?
  elevation       String?
  intensity       String?
  hydration       String?
  recommendations String?
  completed       Boolean  @default(false)
  completedAt     DateTime?
  order           Int      @default(0)
  feedback        Feedback?

  week TrainingWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@index([weekId])
  @@map("training_days")
}

model Feedback {
  id            String   @id @default(cuid())
  trainingDayId String   @unique
  feeling       String
  comment       String?
  createdAt     DateTime @default(now())

  trainingDay TrainingDay @relation(fields: [trainingDayId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}
